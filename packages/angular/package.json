{
  "name": "@ccais/embedded-chatbot-angular",
  "version": "0.1.0",
  "description": "Angular wrapper for the CCAIS embedded chatbot web component.",
  "type": "module",
  "module": "dist/public-api.js",
  "types": "dist/public-api.d.ts",
  "exports": {
    ".": {
      "types": "./dist/public-api.d.ts",
      "import": "./dist/public-api.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "ngc -p tsconfig.json",
    "typecheck": "ngc -p tsconfig.json --noEmit",
    "lint": "ngc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ccais/embedded-chatbot-core": "workspace:*",
    "tslib": "^2.8.1"
  },
  "peerDependencies": {
    "@angular/core": ">=16.0.0"
  },
  "devDependencies": {
    "@angular/compiler-cli": "^18.2.13",
    "@angular/core": "^18.2.13",
    "typescript": "~5.5.4"
  }
}
